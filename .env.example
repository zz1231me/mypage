# ========================================
# 마이홈 환경변수 설정 파일
# ========================================
# 주의: 실제 운영 환경에서는 이 파일을 .gitignore에 추가하고
# 각 환경별로 별도의 .env 파일을 생성하세요.

# ----------------------------------------
# 서버 설정
# ----------------------------------------
NODE_ENV=development
PORT=4000

# ----------------------------------------
# 데이터베이스 설정
# DB_TYPE: sqlite | mysql | mariadb | postgresql | postgres
# ----------------------------------------
DB_TYPE=sqlite
# SQLite 전용 (DB_TYPE=sqlite일 때만 사용)
DB_STORAGE=./database.sqlite

# MySQL / MariaDB / PostgreSQL 전용 (DB_TYPE이 sqlite가 아닐 때 필수)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=myhome
# DB_PASSWORD=secure-db-password
# DB_NAME=myhome
# DB_SSL=false

# ----------------------------------------
# Docker 배포 전용 설정 (docker-compose 사용 시)
# ----------------------------------------
# Docker 배포 시: DB_TYPE=mariadb, DB_HOST=mariadb 로 변경하고 아래 값 설정
# DB_ROOT_PASSWORD=your-secure-root-password  (MariaDB 루트 패스워드, docker-compose 필수)
DB_ROOT_PASSWORD=change-this-root-password

# ----------------------------------------
# JWT 인증 (반드시 변경하세요!)
# ----------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# ----------------------------------------
# 관리자 계정
# ----------------------------------------
# 초기 admin 계정 비밀번호 (설정 후 반드시 변경하세요!)
ADMIN_DEFAULT_PASSWORD=ChangeMe123!

# ----------------------------------------
# 보안 설정
# ----------------------------------------
# 관리자 API 접근 허용 IP 목록 (쉼표 구분, 미설정 시 전체 허용)
# ALLOWED_ADMIN_IPS=127.0.0.1,::1

# ----------------------------------------
# 로그 보존 기간 설정
# ----------------------------------------
# 보안 로그 보존 일수 (기본값: 90)
SECURITY_LOG_RETENTION_DAYS=90

# 에러 로그 보존 일수 (기본값: 30)
ERROR_LOG_RETENTION_DAYS=30

# ----------------------------------------
# Swagger API 문서
# ----------------------------------------
# NODE_ENV=development 일 때 자동으로 http://localhost:4000/api-docs 에서 확인 가능
# NODE_ENV=production 이면 비활성화됨 (별도 환경변수 불필요)
