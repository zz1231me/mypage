{
  "name": "server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "init:roles": "ts-node scripts/init-roles.ts",
    "install:db-drivers": "npm install sqlite3 mysql2 pg @types/pg",
    "setup:sqlite": "ts-node src/scripts/setup-env.ts sqlite",
    "setup:mysql": "ts-node src/scripts/setup-env.ts mysql",
    "setup:mariadb": "ts-node src/scripts/setup-env.ts mariadb",
    "setup:postgresql": "ts-node src/scripts/setup-env.ts postgresql",
    "db:indexes": "cross-env NODE_ENV=development ts-node src/scripts/add-indexes.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "~2.8.6",
    "dotenv": "~17.4.2",
    "express": "~5.2.1",
    "express-async-handler": "~1.2.0",
    "express-rate-limit": "~8.3.2",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "~9.0.3",
    "mariadb": "~3.5.2",
    "morgan": "^1.10.1",
    "multer": "~2.1.1",
    "mysql2": "~3.22.1",
    "node-cache": "^5.1.2",
    "pg": "~8.20.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "~2.17.3",
    "sequelize": "~6.37.8",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "sqlite3": "~6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
