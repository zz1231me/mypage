{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest --runInBand",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "init:roles": "ts-node scripts/init-roles.ts",
    "install:db-drivers": "npm install sqlite3 mysql2 pg @types/pg",
    "setup:sqlite": "ts-node src/scripts/setup-env.ts sqlite",
    "setup:mysql": "ts-node src/scripts/setup-env.ts mysql",
    "setup:mariadb": "ts-node src/scripts/setup-env.ts mariadb",
    "setup:postgresql": "ts-node src/scripts/setup-env.ts postgresql",
    "db:indexes": "cross-env NODE_ENV=development ts-node src/scripts/add-indexes.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "~2.8.5",
    "dotenv": "~16.5.0",
    "exceljs": "^4.4.0",
    "express": "~5.1.0",
    "express-async-handler": "~1.2.0",
    "express-rate-limit": "~7.5.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "~9.0.2",
    "mariadb": "~3.4.2",
    "morgan": "^1.10.1",
    "multer": "~2.0.1",
    "mysql2": "~3.11.3",
    "node-cache": "^5.1.2",
    "pg": "~8.12.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "~2.17.0",
    "sequelize": "~6.37.7",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "sqlite3": "~5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/qrcode": "^1.5.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.3",
    "@types/pg": "^8.11.10",
    "@types/sanitize-html": "^2.16.0",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
