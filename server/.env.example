# ========================================
# 마이홈 서버 환경변수 설정 (로컬 개발용)
# ========================================
# 사용법: cp .env.example .env 후 값 수정
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ----------------------------------------
# 서버 설정
# ----------------------------------------
NODE_ENV=development
PORT=4000

# ----------------------------------------
# 데이터베이스 설정
# DB_TYPE: sqlite | mysql | mariadb | postgresql | postgres
# ----------------------------------------
DB_TYPE=sqlite
# SQLite 전용 (DB_TYPE=sqlite일 때만 사용)
DB_STORAGE=./database.sqlite

# MySQL / MariaDB / PostgreSQL 전용 (DB_TYPE이 sqlite가 아닐 때 필수)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=myhome
# DB_PASSWORD=secure-db-password
# DB_NAME=myhome
# DB_SSL=false

# MySQL/MariaDB 루트 비밀번호 (Docker 환경에서 사용)
# DB_ROOT_PASSWORD=secure-root-password

# ----------------------------------------
# JWT 인증 (반드시 변경하세요!)
# ----------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-32-chars

# ----------------------------------------
# 관리자 계정
# ----------------------------------------
# 초기 admin 계정 비밀번호 (설정 후 반드시 변경하세요!)
ADMIN_DEFAULT_PASSWORD=ChangeMe_2024!

# ----------------------------------------
# 보안 설정
# ----------------------------------------
# 관리자 API 접근 허용 IP 목록 (쉼표 구분, 미설정 시 전체 허용)
# ALLOWED_ADMIN_IPS=127.0.0.1,::1

# ----------------------------------------
# 로그 보존 기간 설정
# ----------------------------------------
# 보안 로그 보존 일수 (기본값: 90)
SECURITY_LOG_RETENTION_DAYS=90

# 에러 로그 보존 일수 (기본값: 30)
ERROR_LOG_RETENTION_DAYS=30
